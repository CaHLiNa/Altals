{
  "name": "example-markdown-extension",
  "displayName": "Example Markdown Extension",
  "version": "0.1.0",
  "type": "module",
  "description": "Minimal workspace-note extension for ScribeFlow platform validation.",
  "engines": {
    "scribeflow": "^1.1.0"
  },
  "main": "./dist/extension.js",
  "extensionKind": ["workspace"],
  "activationEvents": [
    "onCapability:document.summarize",
    "onCommand:scribeflow.markdown.summarize",
    "onView:exampleMarkdownExtension.notesView"
  ],
  "contributes": {
    "capabilities": [
      {
        "id": "document.summarize",
        "inputs": {
          "document": {
            "type": "workspaceFile",
            "required": true,
            "extensions": [
              ".md",
              ".markdown",
              ".txt"
            ]
          }
        },
        "outputs": {
          "summary": {
            "type": "inlineText",
            "mediaType": "text/plain",
            "required": true
          }
        }
      }
    ],
    "commands": [
      {
        "command": "scribeflow.markdown.summarize",
        "title": "Summarize Note",
        "category": "Notes"
      },
      {
        "command": "exampleMarkdownExtension.refreshNotesView",
        "title": "Refresh Notes View",
        "category": "Notes"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "exampleMarkdownExtension.notes",
          "title": "Notes Tools"
        }
      ]
    },
    "views": {
      "exampleMarkdownExtension.notes": [
        {
          "id": "exampleMarkdownExtension.notesView",
          "name": "Note Summary",
          "when": "resourceExtname == .md || resource.kind == workspace"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "scribeflow.markdown.summarize",
          "when": "resourceExtname == .md || resource.kind == workspace"
        }
      ],
      "view/title": [
        {
          "command": "exampleMarkdownExtension.refreshNotesView",
          "when": "activeView == extension:exampleMarkdownExtension.notes"
        }
      ],
      "view/item/context": [
        {
          "command": "exampleMarkdownExtension.refreshNotesView",
          "when": "viewItem.contextValue == note-section"
        }
      ]
    },
    "keybindings": [
      {
        "command": "scribeflow.markdown.summarize",
        "key": "mod+alt+m",
        "when": "resourceExtname == .md || resource.kind == workspace"
      }
    ],
    "configuration": {
      "title": "Example Markdown Extension",
      "properties": {
        "exampleMarkdownExtension.summaryStyle": {
          "type": "string",
          "default": "bullet",
          "description": "Summary style for the example provider."
        }
      }
    }
  },
  "permissions": {
    "readWorkspaceFiles": true
  }
}
