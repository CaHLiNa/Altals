{
  "name": "retain-pdf",
  "displayName": "%extension.displayName%",
  "version": "0.1.0",
  "type": "module",
  "description": "%extension.description%",
  "engines": {
    "scribeflow": "^1.1.0"
  },
  "main": "./extension.js",
  "extensionKind": [
    "workspace"
  ],
  "capabilities": [
    "pdf.translate"
  ],
  "activationEvents": [
    "onCapability:pdf.translate",
    "onCommand:retainPdf.translateCurrent",
    "onCommand:retainPdf.refreshView",
    "onView:retainPdf.panel"
  ],
  "contributes": {
    "capabilities": [
      {
        "id": "pdf.translate",
        "inputs": {
          "document": {
            "type": "workspaceFile",
            "required": true,
            "extensions": [
              ".pdf"
            ]
          },
          "reference": {
            "type": "reference",
            "required": false
          }
        },
        "outputs": {
          "translatedPdf": {
            "type": "artifact",
            "mediaType": "application/pdf",
            "required": false
          },
          "translatedText": {
            "type": "artifact",
            "mediaType": "text/markdown",
            "required": false
          },
          "log": {
            "type": "artifact",
            "mediaType": "text/plain",
            "required": true
          },
          "summary": {
            "type": "inlineText",
            "mediaType": "text/plain",
            "required": true
          }
        }
      }
    ],
    "commands": [
      {
        "command": "retainPdf.translateCurrent",
        "title": "%command.translateCurrent.title%",
        "category": "%category.retainPdf%"
      },
      {
        "command": "retainPdf.refreshView",
        "title": "%command.refreshView.title%",
        "category": "%category.retainPdf%"
      },
      {
        "command": "retainPdf.captureContext",
        "title": "%command.captureContext.title%",
        "category": "%category.retainPdf%"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "retainPdf.tools",
          "title": "%extension.displayName%"
        }
      ]
    },
    "views": {
      "retainPdf.tools": [
        {
          "id": "retainPdf.panel",
          "name": "%extension.displayName%",
          "when": "resourceExtname == .pdf || resource.kind == pdf"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "retainPdf.translateCurrent",
          "when": "resourceExtname == .pdf || resource.kind == pdf"
        }
      ],
      "pdf.preview.actions": [
        {
          "command": "retainPdf.translateCurrent",
          "when": "resource.kind == pdf"
        }
      ],
      "view/title": [
        {
          "command": "retainPdf.refreshView",
          "when": "activeView == extension:retainPdf.tools"
        }
      ],
      "view/item/context": [
        {
          "command": "retainPdf.translateCurrent",
          "when": "viewItem.contextValue == retain-pdf-target"
        }
      ]
    },
    "configuration": {
      "title": "%extension.displayName%",
      "properties": {
        "retainPdf.ocrProvider": {
          "type": "string",
          "default": "mineru",
          "title": "%setting.ocrProvider.title%",
          "description": "%setting.ocrProvider.description%",
          "enum": [
            "mineru",
            "paddle"
          ],
          "enumItemLabels": [
            "MinerU",
            "PaddleOCR"
          ]
        },
        "retainPdf.mineruToken": {
          "type": "string",
          "default": "",
          "title": "%setting.mineruToken.title%",
          "description": "%setting.mineruToken.description%",
          "secureStorage": true
        },
        "retainPdf.paddleToken": {
          "type": "string",
          "default": "",
          "title": "%setting.paddleToken.title%",
          "description": "%setting.paddleToken.description%",
          "secureStorage": true
        },
        "retainPdf.modelBaseUrl": {
          "type": "string",
          "default": "https://api.deepseek.com/v1",
          "title": "%setting.modelBaseUrl.title%",
          "description": "%setting.modelBaseUrl.description%"
        },
        "retainPdf.model": {
          "type": "string",
          "default": "deepseek-v4-flash",
          "title": "%setting.model.title%",
          "description": "%setting.model.description%"
        },
        "retainPdf.modelApiKey": {
          "type": "string",
          "default": "",
          "title": "%setting.modelApiKey.title%",
          "description": "%setting.modelApiKey.description%",
          "secureStorage": true
        },
        "retainPdf.workflow": {
          "type": "string",
          "default": "book",
          "title": "%setting.workflow.title%",
          "description": "%setting.workflow.description%",
          "enum": [
            "book",
            "translate"
          ],
          "enumItemLabels": [
            "%setting.workflow.book%",
            "%setting.workflow.translate%"
          ]
        },
        "retainPdf.pageRanges": {
          "type": "string",
          "default": "",
          "title": "%setting.pageRanges.title%",
          "description": "%setting.pageRanges.description%"
        },
        "retainPdf.developerMode": {
          "type": "boolean",
          "default": true,
          "title": "%setting.developerMode.title%",
          "description": "%setting.developerMode.description%"
        },
        "retainPdf.pollIntervalSeconds": {
          "type": "number",
          "default": 5,
          "title": "%setting.pollIntervalSeconds.title%",
          "description": "%setting.pollIntervalSeconds.description%"
        },
        "retainPdf.timeoutSeconds": {
          "type": "number",
          "default": 1800,
          "title": "%setting.timeoutSeconds.title%",
          "description": "%setting.timeoutSeconds.description%"
        }
      }
    }
  },
  "permissions": {
    "readWorkspaceFiles": true,
    "readReferenceLibrary": true,
    "spawnProcess": true
  }
}
