{
  "schemaVersion": 1,
  "id": "scribeflow-pdf-translator",
  "name": "ScribeFlow PDF Translator",
  "version": "0.1.0",
  "description": "A ScribeFlow-owned PDF translation plugin package. Drop the real plugin runner and its dependencies into this folder.",
  "capabilities": ["pdf.translate"],
  "runtime": {
    "type": "cli",
    "command": "bin/scribeflow-pdf-translator"
  },
  "permissions": {
    "readWorkspaceFiles": true,
    "readReferenceLibrary": true,
    "writeArtifacts": true,
    "writeReferenceMetadata": false,
    "spawnProcess": true,
    "network": "optional"
  },
  "settingsSchema": {
    "modelProvider": {
      "type": "string",
      "default": "openai",
      "label": "Model provider",
      "description": "Provider used by the plugin runner.",
      "options": [
        { "value": "openai", "label": "OpenAI" },
        { "value": "local", "label": "Local model" },
        { "value": "custom", "label": "Custom endpoint" }
      ]
    },
    "model": {
      "type": "string",
      "default": "gpt-4.1-mini",
      "label": "Model",
      "description": "Model name passed to the plugin runner."
    },
    "targetLanguage": {
      "type": "string",
      "default": "zh-CN",
      "label": "Target language",
      "description": "Translation target language."
    },
    "translationMode": {
      "type": "string",
      "default": "bilingual",
      "label": "Translation mode",
      "options": [
        { "value": "bilingual", "label": "Bilingual PDF" },
        { "value": "translatedOnly", "label": "Translated PDF only" }
      ]
    },
    "preserveLayout": {
      "type": "boolean",
      "default": true,
      "label": "Preserve layout"
    },
    "chunkSize": {
      "type": "integer",
      "default": 12,
      "label": "Chunk size"
    }
  },
  "inputs": {
    "pdfPath": {
      "type": "file",
      "required": true,
      "extensions": ["pdf"]
    }
  },
  "outputs": {
    "translatedPdf": {
      "type": "artifact",
      "mediaType": "application/pdf",
      "required": false
    },
    "bilingualPdf": {
      "type": "artifact",
      "mediaType": "application/pdf",
      "required": false
    },
    "log": {
      "type": "artifact",
      "mediaType": "text/plain",
      "required": true
    }
  }
}
