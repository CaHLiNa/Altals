{
  "name": "scribeflow",
  "private": true,
  "version": "1.0.16",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 1420 --strictPort",
    "build": "vite build",
    "preview": "vite preview",
    "check": "npm run build",
    "verify": "npm run guard:ui-bridges && npm run guard:pdf-runtime && npm run guard:textmate-runtime && npm run probe:extension-host && npm run probe:extension-markdown-host && npm run probe:extension-view-result-entries && npm run probe:extension-pdf-view-result-entries && npm run probe:extension-direct-view-host && npm run probe:extension-capability-execution && npm run probe:extension-capability-schema && npm run probe:extension-activation-guards && npm run probe:extension-permission-guards && npm run probe:extension-disable-guards && npm run probe:extension-enable-activation && npm run probe:extension-deactivation-host && npm run probe:extension-secure-settings-bridge && npm run probe:extension-sidebar-routing && npm run probe:extension-text-preview-fallback && npm run probe:extension-artifact-preview-entries && npm run probe:extension-task-timeline && npm run probe:extension-host-recovery && npm run probe:extension-window-interruption && npm run probe:extension-host-ui-interruption && npm run probe:extension-quickpick-multiselect && npm run probe:extension-window-prompt-multiselect && npm run probe:extension-quickpick-host-multiselect && npm run build && npm run check:bundle && npm run check:rust && npm run test:rust",
    "guard:ui-bridges": "node scripts/check-ui-bridges.mjs",
    "guard:pdf-runtime": "node scripts/check-pdf-runtime-boundary.mjs",
    "guard:textmate-runtime": "node scripts/check-textmate-runtime-boundary.mjs",
    "probe:extension-host": "node scripts/probe-extension-host.mjs",
    "probe:extension-markdown-host": "node scripts/probe-extension-markdown-host.mjs",
    "probe:extension-view-result-entries": "node scripts/probe-extension-view-result-entries.mjs",
    "probe:extension-pdf-view-result-entries": "node scripts/probe-extension-pdf-view-result-entries.mjs",
    "probe:extension-direct-view-host": "node scripts/probe-extension-direct-view-host.mjs",
    "probe:extension-capability-execution": "node scripts/probe-extension-capability-execution.mjs",
    "probe:extension-capability-schema": "node scripts/probe-extension-capability-schema.mjs",
    "probe:extension-activation-guards": "node scripts/probe-extension-activation-guards.mjs",
    "probe:extension-permission-guards": "node scripts/probe-extension-permission-guards.mjs",
    "probe:extension-disable-guards": "node scripts/probe-extension-disable-guards.mjs",
    "probe:extension-enable-activation": "node scripts/probe-extension-enable-activation.mjs",
    "probe:extension-deactivation-host": "node scripts/probe-extension-deactivation-host.mjs",
    "probe:extension-secure-settings-bridge": "node scripts/probe-extension-secure-settings-bridge.mjs",
    "probe:extension-sidebar-routing": "node scripts/probe-extension-sidebar-routing.mjs",
    "probe:extension-text-preview-fallback": "node scripts/probe-extension-text-preview-fallback.mjs",
    "probe:extension-artifact-preview-entries": "node scripts/probe-extension-artifact-preview-entries.mjs",
    "probe:extension-task-timeline": "node scripts/probe-extension-task-timeline.mjs",
    "probe:extension-host-recovery": "cargo run --manifest-path src-tauri/Cargo.toml --bin extension-host-recovery-probe",
    "probe:extension-window-interruption": "node scripts/probe-extension-window-interruption.mjs",
    "probe:extension-host-ui-interruption": "cargo run --manifest-path src-tauri/Cargo.toml --bin extension-host-ui-interrupt-probe",
    "probe:extension-quickpick-multiselect": "node scripts/probe-extension-quickpick-multiselect.mjs",
    "probe:extension-window-prompt-multiselect": "node scripts/probe-extension-window-prompt-multiselect.mjs",
    "probe:extension-quickpick-host-multiselect": "node scripts/probe-extension-quickpick-host-multiselect.mjs",
    "check:bundle": "node scripts/check-bundle-budget.mjs",
    "version:bump": "node scripts/bump-version.mjs",
    "release:check-version": "node scripts/check-release-version.mjs",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "tauri": "tauri"
  },
